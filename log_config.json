{
  "logs": [
    {
      "name": "Domotica",
      "type": "folder",
      "path": "/var/log/domotica/",
      "pattern": "*.log",
      "format": "domotica",
      "active": true,
      "limit": 2000
    },
    {
      "name": "Vorige",
      "type": "folder",
      "path": "/var/log/domotica/",
      "pattern": "*.log.1",
      "format": "domotica",
      "active": false,
      "limit": 2000
    },
    {
      "name": "MQTT",
      "type": "folder",
      "path": "/var/log/mqtt/",
      "pattern": "*.log",
      "format": "domotica",
      "active": false,
      "limit": 2000
    },
    {
      "name": "Vorige",
      "type": "folder",
      "path": "/var/log/mqtt/",
      "pattern": "*.log.1",
      "format": "domotica",
      "active": false,
      "limit": 2000
    },
    {
      "name": "Access Logs",
      "type": "folder",
      "path": "/var/log/nginx/",
      "pattern": "*access.log",
      "format": "nginx_error",
      "active": false,
      "limit": 1000
    },
    {
      "name": "Error Logs",
      "type": "folder",
      "path": "/var/log/nginx/",
      "pattern": "*error.log",
      "format": "nginx_error",
      "active": true,
      "limit": 1000
    }
  ],
