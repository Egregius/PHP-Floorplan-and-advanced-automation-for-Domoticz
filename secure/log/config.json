{
  "logs": [
    {
      "name": "Domotica",
      "type": "folder",
      "path": "/var/log/domotica/",
      "pattern": "*.log",
      "format": "domotica",
      "active": true,
      "limit": 2000
    },
    {
      "name": "Vorige",
      "type": "folder",
      "path": "/var/log/domotica/",
      "pattern": "*.log.1",
      "format": "domotica",
      "active": false,
      "limit": 2000
    },
    {
      "name": "Error Logs",
      "type": "folder",
      "path": "/var/log/nginx/",
      "pattern": "*error.log",
      "format": "nginx_error",
      "active": true,
      "limit": 1000
    },
    {
      "name": "PHP Errors",
      "type": "file",
      "path": "/var/log/php8.2-fpm.log",
      "format": "php_error",
      "active": false,
      "limit": 100
    }
  ],
